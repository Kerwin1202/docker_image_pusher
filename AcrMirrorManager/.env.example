# 懒人版：普通部署只需要改下面 5 个字段，其它字段先不要动。
# RegistryV2__Registry
# RegistryV2__Namespace
# RegistryV2__Username
# RegistryV2__Password
# GitHubMirror__Token
# 如果部署 fork 仓库，再改 GitHubMirror__RepositoryUrl。

# docker-compose 暴露到宿主机的访问端口。
APP_HTTP_PORT=15187

# 容器时区。
TZ=Asia/Shanghai

# Docker 构建基础镜像，默认使用微软官方镜像。
# 如果你有自己的镜像代理或私有加速镜像，可以在部署环境里覆盖这两个值。
SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:9.0
ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:9.0

# 默认使用 RegistryV2，适合阿里云 ACR 个人版。
# AliyunApi 是旧模式，功能不完整，也不适用于阿里云 ACR 个人版。
RegistryBackend__Mode=RegistryV2

# 阿里云 ACR Registry 地址。
RegistryV2__Registry=registry.cn-shanghai.aliyuncs.com

# 阿里云 ACR 命名空间。
RegistryV2__Namespace=your-aliyun-acr-namespace

# 阿里云 ACR 登录用户名和密码，通常就是 docker login 使用的账号密码。
RegistryV2__Username=your-aliyun-acr-username
RegistryV2__Password=your-aliyun-acr-password

# 是否把 images.txt 里已经用 # 注释的镜像也纳入页面列表。
# true：注释和未注释的镜像都会显示，方便管理历史镜像。
# false：只显示当前未注释、会被 docker_image_pusher 处理的镜像。
RegistryV2__IncludeCommentedImages=true

# 每次刷新 Tag 时，最多对多少个 Tag 额外请求 manifest，确认它是否真的可拉取并获取 digest。
# 数值越大，Tag 状态越完整，但远端请求越多。
RegistryV2__ManifestProbeLimit=50

# 本地缓存文件路径，用于保存仓库、Tag、Action 追踪和待刷新任务。
RegistryV2__CachePath=App_Data/registry-v2-cache.json

# 每天几点自动刷新“未推送”的仓库，0 表示每天 0 点后执行一次。
RegistryV2__DailyMissingRefreshHour=0

# GitHub 镜像仓库地址。
# 这里仍然需要配置，因为管理页面要通过 GitHub API 读写这个仓库根目录的 images.txt。
# 默认值就是当前合并后的仓库；部署 fork 仓库时，把这里改成你的 fork 地址。
GitHubMirror__RepositoryUrl=https://github.com/Kerwin1202/docker_image_pusher

# GitHub token，用于读取和更新上面仓库里的 images.txt。
# fine-grained token 至少需要该仓库 Contents: Read and write 权限。
GitHubMirror__Token=github_pat_xxx

# 页面提交新镜像时，“只处理本次镜像”复选框的默认值。
# true：默认会把 images.txt 里其它未注释镜像加 #，本次 Action 主要处理新提交的镜像。
# false：默认不改其它镜像行，原来启用的继续启用，原来注释的继续注释，只追加/恢复本次提交的镜像。
GitHubMirror__CommentOthersByDefault=true

# 下面是 AliyunApi 旧模式配置。
# 该模式功能不完整，不适用于阿里云 ACR 个人版；普通使用请保持 RegistryBackend__Mode=RegistryV2。
AliyunAcr__AccessKeyId=
AliyunAcr__AccessKeySecret=
AliyunAcr__RegionId=cn-shanghai
AliyunAcr__InstanceId=
AliyunAcr__Namespace=
AliyunAcr__Endpoint=cr.cn-shanghai.aliyuncs.com
AliyunAcr__PageSize=100
